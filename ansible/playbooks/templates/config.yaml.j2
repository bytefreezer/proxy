# ByteFreezer Proxy Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Host: {{ inventory_hostname }}

app:
  name: {{ config.app.name }}
  version: {{ config.app.version }}

# Logging configuration
logging:
  level: {{ config.logging.level }}
  encoding: {{ config.logging.encoding }}

# API server configuration
server:
  api_port: {{ config.server.api_port }}

# Plugin-based input configuration (populated from Control)
inputs: []

# Account-based configuration - proxy polls Control for all tenants + datasets
# IMPORTANT: bearer_token is the account-specific API key used for ALL authentication
account_id: "{{ config.account_id }}"
bearer_token: "{{ bytefreezer_proxy_bearer_token }}"  # Account-specific API key for all auth (config polling AND health reporting)
control_url: "{{ config.control_url }}"
config_mode: "{{ config.config_mode | default('control-only') }}"  # local-only | control-only

# Configuration polling from Control
config_polling:
  enabled: {{ config.config_polling.enabled | lower }}
  interval_seconds: {{ config.config_polling.interval_seconds }}
  timeout_seconds: {{ config.config_polling.timeout_seconds }}
  cache_directory: "{{ config.config_polling.cache_directory }}"
  retry_on_error: {{ config.config_polling.retry_on_error | lower }}

# Bytefreezer-receiver configuration
receiver:
  base_url: "{{ config.receiver.base_url }}"
  timeout_seconds: {{ config.receiver.timeout_seconds }}
  upload_worker_count: {{ config.receiver.upload_worker_count }}    # Number of upload workers (aligned with receiver)
  max_idle_conns: {{ config.receiver.max_idle_conns }}        # HTTP connection pool size
  max_conns_per_host: {{ config.receiver.max_conns_per_host }}     # Max connections per host

  # Dedicated retry HTTP client configuration (defaults to same values as upload client)
  # retry_max_idle_conns: 10      # HTTP connection pool size for retries (optional)
  # retry_max_conns_per_host: 6   # Max connections per host for retries (optional)

# Batch processing configuration
batching:
  enabled: {{ config.batching.enabled | lower }}
  max_lines: {{ config.batching.max_lines }}          # Max lines per batch (0 = disabled)
  max_bytes: {{ config.batching.max_bytes }}   # Max bytes per batch - 10MB (0 = disabled)
  timeout_seconds: {{ config.batching.timeout_seconds }}
  compression_enabled: {{ config.batching.compression_enabled | lower }}
  compression_level: {{ config.batching.compression_level }}

# SOC alerting configuration
soc:
  enabled: {{ config.soc.enabled | lower }}
  endpoint: "{{ config.soc.endpoint }}"
  timeout_seconds: {{ config.soc.timeout_seconds }}

# OpenTelemetry configuration (disabled by default)
otel:
  enabled: {{ config.otel.enabled | lower }}
  service_name: "{{ config.otel.service_name }}"
  scrapeIntervalseconds: {{ config.otel.scrapeIntervalseconds }}

# Housekeeping configuration
housekeeping:
  enabled: {{ config.housekeeping.enabled | lower }}
  intervalseconds: {{ config.housekeeping.intervalseconds }}

# Local spooling for failed uploads
spooling:
  enabled: {{ config.spooling.enabled | lower }}
  directory: "{{ config.spooling.directory }}"
  max_size_bytes: {{ config.spooling.max_size_bytes }}  # 1GB
  retry_attempts: {{ config.spooling.retry_attempts }}
  retry_interval_seconds: {{ config.spooling.retry_interval_seconds }}  # 1 minute
  cleanup_interval_seconds: {{ config.spooling.cleanup_interval_seconds }}  # 5 minutes
  keep_src: {{ config.spooling.keep_src | lower }}

# Health reporting configuration for service registration and monitoring
health_reporting:
  enabled: {{ config.health_reporting.enabled | lower }}
  report_interval: {{ config.health_reporting.report_interval }}  # seconds
  timeout_seconds: {{ config.health_reporting.timeout_seconds }}
  register_on_startup: {{ config.health_reporting.register_on_startup | lower }}

# Tenant validation configuration (Layer 4 optimization - proactive tenant status checking)
tenant_validation:
  enabled: {{ config.tenant_validation.enabled | lower }}
  cache_ttl_seconds: {{ config.tenant_validation.cache_ttl_seconds }}  # 5 minutes for active tenants
  inactive_cache_ttl_seconds: {{ config.tenant_validation.inactive_cache_ttl_seconds }}  # 1 hour for inactive tenants (reduces API load)
  timeout_seconds: {{ config.tenant_validation.timeout_seconds }}

# Error tracking configuration (uses control_service.base_url)
error_tracking:
  enabled: {{ config.error_tracking.enabled | default(true) | lower }}

# Development mode
dev: {{ config.dev | lower }}