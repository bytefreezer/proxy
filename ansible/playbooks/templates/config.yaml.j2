# ByteFreezer Proxy Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Host: {{ inventory_hostname }}

app:
  name: {{ config.app.name }}
  version: {{ config.app.version }}

# Logging configuration
logging:
  level: {{ config.logging.level }}
  encoding: {{ config.logging.encoding }}

# API server configuration  
server:
  api_port: {{ config.server.api_port }}

# Plugin-based input configuration
inputs:
{% for input in config.inputs %}
  # {{ input.name }} - {{ input.type }} plugin
  - type: "{{ input.type }}"
    name: "{{ input.name }}"
    config:
{% for key, value in input.config.items() %}
{% if value is string %}
      {{ key }}: "{{ value }}"
{% else %}
      {{ key }}: {{ value }}
{% endif %}
{% endfor %}
{% endfor %}

# Global tenant configuration
tenant_id: "{{ config.tenant_id }}"
bearer_token: "{{ config.bearer_token }}"

# Bytefreezer-receiver configuration
receiver:
  base_url: "{{ config.receiver.base_url }}"
  timeout_seconds: {{ config.receiver.timeout_seconds }}
  upload_worker_count: {{ config.receiver.upload_worker_count | default(5) }}    # Number of upload workers (aligned with receiver)
  max_idle_conns: {{ config.receiver.max_idle_conns | default(10) }}        # HTTP connection pool size
  max_conns_per_host: {{ config.receiver.max_conns_per_host | default(6) }}     # Max connections per host

  # Dedicated retry HTTP client configuration (defaults to same values as upload client)
  # retry_max_idle_conns: {{ config.receiver.retry_max_idle_conns | default(10) }}      # HTTP connection pool size for retries (optional)
  # retry_max_conns_per_host: {{ config.receiver.retry_max_conns_per_host | default(6) }}   # Max connections per host for retries (optional)

# Batch processing configuration
batching:
  enabled: {{ config.batching.enabled | default(true) | lower }}
  max_lines: {{ config.batching.max_lines | default(0) }}       # Max lines per batch (0 = disabled)
  max_bytes: {{ config.batching.max_bytes | default(20971520) }}   # Max bytes per batch - 20MB (0 = disabled)
  timeout_seconds: {{ config.batching.timeout_seconds | default(60) }}   # Timeout always takes priority
  compression_enabled: {{ config.batching.compression_enabled | default(true) | lower }}
  compression_level: {{ config.batching.compression_level | default(6) }}

# SOC alerting configuration
soc:
  enabled: {{ config.soc.enabled | lower }}
  endpoint: "{{ config.soc.endpoint }}"
  timeout: {{ config.soc.timeout }}

# OpenTelemetry configuration
otel:
  enabled: {{ config.otel.enabled | lower }}
  service_name: "{{ config.otel.service_name }}"
  scrapeIntervalseconds: {{ config.otel.scrapeIntervalseconds }}
  # Prometheus mode - expose metrics on HTTP endpoint for scraping
  prometheus_mode: {{ config.otel.prometheus_mode | lower }}
  metrics_port: {{ config.otel.metrics_port }}
  # Bind to all interfaces for external scraping
  metrics_host: "{{ config.otel.metrics_host }}"

# Housekeeping configuration
housekeeping:
  enabled: {{ config.housekeeping.enabled | lower }}
  intervalseconds: {{ config.housekeeping.intervalseconds }}

# Local spooling for failed uploads
spooling:
  enabled: {{ config.spooling.enabled | lower }}
  directory: "{{ config.spooling.directory }}"
  max_size_bytes: {{ config.spooling.max_size_bytes }}
  retry_attempts: {{ config.spooling.retry_attempts }}
  retry_interval_seconds: {{ config.spooling.retry_interval_seconds }}
  cleanup_interval_seconds: {{ config.spooling.cleanup_interval_seconds }}
  keep_src: {{ config.spooling.keep_src | lower }}
  queue_processing_interval_seconds: {{ config.spooling.queue_processing_interval_seconds | default(30) }}

# Health reporting configuration
health_reporting:
  enabled: {{ config.health_reporting.enabled | default(true) | lower }}
  control_url: "{{ config.health_reporting.control_url | default('http://localhost:8082') }}"
  report_interval: {{ config.health_reporting.report_interval | default(30) }}  # Interval in seconds
  timeout_seconds: {{ config.health_reporting.timeout_seconds | default(10) }}
  register_on_startup: {{ config.health_reporting.register_on_startup | default(true) | lower }}

# Development mode
dev: {{ config.dev | lower }}